{
  "name": "travel-packlist-root",
  "version": "1.7.2",
  "license": "MIT",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "changelog": "conventional-changelog -i CHANGELOG.md -n util/conventionalcommits.mjs",
    "version": "pnpm run changelog -s && git add CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "release-notes": "conventional-changelog -r 2 -n util/conventionalcommits.mjs -o",
    "create-prettierignore": "node util/create-prettierignore.mjs",
    "prepare": "husky",
    "dev": "nx serve travel-packlist",
    "start": "nx serve travel-packlist-web"
  },
  "nx": {
    "includedScripts": [
      "dev",
      "start"
    ],
    "implicitDependencies": [
      "check-plugin",
      "libs/*",
      "apps/*"
    ],
    "targets": {
      "design": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx storybook design-system",
            "nx run design-system:compile-styles:watch"
          ],
          "parallel": true
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "dependsOn": [
          "check-sync-playwright-version"
        ],
        "options": {
          "lintFilePatterns": [
            "*.*",
            "util/*.*"
          ]
        }
      },
      "markdownlint": {
        "executor": "@travel-packlist/check-plugin:markdown",
        "options": {
          "pattern": "*.md",
          "exclude": [
            "AGENTS.md",
            "CHANGELOG.md"
          ]
        }
      },
      "check-sync-playwright-version": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node util/check-sync-playwright-version.mjs"
        }
      },
      "create-prettierignore": {
        "executor": "nx:run-script",
        "options": {
          "script": "create-prettierignore"
        },
        "inputs": [
          "{workspaceRoot}/util/create-prettierignore.mjs",
          "{workspaceRoot}/**/.gitignore"
        ],
        "outputs": [
          "{workspaceRoot}/.prettierignore"
        ],
        "cache": true
      },
      "format": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "create-prettierignore"
        ],
        "options": {
          "command": "nx format:write --all"
        },
        "configurations": {
          "ci": {
            "command": "nx format:check --all"
          },
          "pre-commit": {
            "command": "nx format:write --uncommitted"
          }
        }
      },
      "dead-code": {
        "executor": "@travel-packlist/check-plugin:dead-code-summary",
        "dependsOn": [
          "^dead-code"
        ],
        "inputs": [
          "{workspaceRoot}/dist/**/dead-code/imports.json",
          "{workspaceRoot}/dist/**/dead-code/exports.json"
        ],
        "cache": false
      }
    }
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "nx",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract"
    ]
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^21.2.16",
    "@angular/build": "^21.2.16",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/compiler-cli": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/localize": "^21.2.17",
    "@angular/platform-browser": "^21.2.17",
    "@angular/router": "^21.2.17",
    "@angular/service-worker": "^21.2.17",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nx/angular": "23.0.0",
    "@nx/devkit": "23.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "browserslist": "^4.28.4",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "nx": "23.0.0",
    "peggy": "^5.1.0",
    "rxjs": "~7.8.2",
    "showdown": "^2.1.0",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/cli": "^21.2.16",
    "@cspell/cspell-types": "^10.0.1",
    "@cspell/dict-de-de": "^4.1.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@nx/esbuild": "23.0.0",
    "@nx/eslint": "23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/playwright": "23.0.0",
    "@nx/plugin": "23.0.0",
    "@nx/storybook": "23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/web": "23.0.0",
    "@nx/workspace": "23.0.0",
    "@playwright/test": "1.60.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/angular": "^10.4.6",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.41",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^25.9.4",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/utils": "^8.61.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "angular-eslint": "^21.4.0",
    "autoprefixer": "^10.5.0",
    "conventional-changelog": "^7.2.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.6.0",
    "jsonc-eslint-parser": "^3.1.0",
    "markdownlint-cli": "^0.49.0",
    "minimatch": "^10.2.5",
    "nx-stylelint": "^19.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.6",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.61.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
