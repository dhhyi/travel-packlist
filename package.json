  "devDependencies": {
    "@angular/cli": "22.0.7",
    "@cspell/cspell-types": "^10.0.1",
    "@cspell/dict-de-de": "^4.1.2",
    "@nx/esbuild": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@nx/plugin": "23.1.0",
    "@nx/storybook": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/web": "23.1.0",
    "@nx/workspace": "23.1.0",
    "@playwright/test": "1.60.0",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-themes": "10.5.2",
    "@storybook/angular": "10.5.2",
    "@swc-node/register": "^1.12.0",
    "@swc/core": "^1.15.43",
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/utils": "^8.64.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "angular-eslint": "22.1.0",
    "autoprefixer": "^10.5.4",
    "conventional-changelog": "^7.2.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cspell": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-storybook": "^10.5.2",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "markdownlint-cli": "^0.49.1",
    "minimatch": "^10.2.5",
    "nx-stylelint": "^19.0.0",
    "postcss": "^8.5.19",
    "storybook": "10.5.2",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24"
  },
  "license": "MIT",
  "name": "travel-packlist-root",
  "nx": {
    "implicitDependencies": [
      "check-plugin",
      "libs/*",
      "apps/*"
    ],
    "includedScripts": [
      "dev",
      "start"
    ],
    "targets": {
      "check-sync-playwright-version": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node util/check-sync-playwright-version.mjs"
        }
      },
      "create-prettierignore": {
        "cache": true,
        "executor": "nx:run-script",
        "inputs": [
          "{workspaceRoot}/util/create-prettierignore.mjs",
          "{workspaceRoot}/**/.gitignore"
        ],
        "options": {
          "script": "create-prettierignore"
        },
        "outputs": [
          "{workspaceRoot}/.prettierignore"
        ]
      },
      "dead-code": {
        "cache": false,
        "dependsOn": [
          "^dead-code"
        ],
        "executor": "@travel-packlist/check-plugin:dead-code-summary",
        "inputs": [
          "{workspaceRoot}/dist/**/dead-code/imports.json",
          "{workspaceRoot}/dist/**/dead-code/exports.json"
        ]
      },
      "design": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx storybook design-system",
            "nx run design-system:compile-styles:watch"
          ],
          "parallel": true
        }
      },
      "format": {
        "configurations": {
          "ci": {
            "command": "nx format:check --all"
          },
          "pre-commit": {
            "command": "nx format:write --uncommitted"
          }
        },
        "dependsOn": [
          "create-prettierignore"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "nx format:write --all"
        }
      },
      "lint": {
        "configurations": {
          "pre-commit": {
            "command": "eslint --max-warnings 0 *.{js,mjs,ts} util/*.mjs --fix"
          }
        },
        "dependsOn": [
          "check-sync-playwright-version"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint --max-warnings 0 *.{js,mjs,ts} util/*.mjs"
        }
      },
      "markdownlint": {
        "executor": "@travel-packlist/check-plugin:markdown",
        "options": {
          "exclude": [
            "AGENTS.md",
            "CHANGELOG.md"
          ],
          "pattern": "*.md"
        }
      }
    }
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract"
    ],
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "nx",
      "sharp"
    ]
  },
  "private": true,
  "scripts": {
    "changelog": "conventional-changelog -i CHANGELOG.md -n util/conventionalcommits.mjs",
    "create-prettierignore": "node util/create-prettierignore.mjs",
    "dev": "nx serve travel-packlist",
    "postversion": "git push && git push --tags",
    "prepare": "husky",
    "release-notes": "conventional-changelog -r 2 -n util/conventionalcommits.mjs -o",
    "start": "nx serve travel-packlist-web",
    "version": "pnpm run changelog -s && git add CHANGELOG.md"
  },
  "version": "1.7.2"
}
