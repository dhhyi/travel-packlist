{
  "name": "travel-packlist-root",
  "version": "1.5.0",
  "license": "MIT",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "changelog": "conventional-changelog -i CHANGELOG.md -n util/conventionalcommits.mjs",
    "version": "pnpm run changelog -- -s && git add CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "release-notes": "conventional-changelog -r 2 -n util/conventionalcommits.mjs -o",
    "create-prettierignore": "node util/create-prettierignore.mjs",
    "prepare": "husky",
    "dev": "nx serve travel-packlist",
    "start": "nx serve travel-packlist-web"
  },
  "nx": {
    "includedScripts": [
      "dev",
      "start"
    ],
    "implicitDependencies": [
      "check-plugin",
      "libs/*",
      "apps/*"
    ],
    "targets": {
      "design": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx storybook design-system",
            "nx run design-system:compile-styles:watch"
          ],
          "parallel": true
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "dependsOn": [
          "check-sync-playwright-version"
        ],
        "options": {
          "lintFilePatterns": [
            "*.*",
            "util/*.*"
          ]
        }
      },
      "markdownlint": {
        "executor": "@travel-packlist/check-plugin:markdown",
        "options": {
          "pattern": "*.md"
        }
      },
      "check-sync-playwright-version": {
        "executor": "nx:run-commands",
        "options": {
          "command": "node util/check-sync-playwright-version.mjs"
        }
      },
      "create-prettierignore": {
        "executor": "nx:run-script",
        "options": {
          "script": "create-prettierignore"
        },
        "inputs": [
          "{workspaceRoot}/util/create-prettierignore.mjs",
          "{workspaceRoot}/**/.gitignore"
        ],
        "outputs": [
          "{workspaceRoot}/.prettierignore"
        ],
        "cache": true
      },
      "format": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "create-prettierignore"
        ],
        "options": {
          "command": "nx format:write --all"
        },
        "configurations": {
          "ci": {
            "command": "nx format:check --all"
          },
          "pre-commit": {
            "command": "nx format:write --uncommitted"
          }
        }
      },
      "dead-code": {
        "executor": "@travel-packlist/check-plugin:dead-code-summary",
        "dependsOn": [
          "^dead-code"
        ],
        "inputs": [
          "{workspaceRoot}/dist/**/dead-code/imports.json",
          "{workspaceRoot}/dist/**/dead-code/exports.json"
        ],
        "cache": false
      }
    }
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "nx",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract"
    ]
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/localize": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/service-worker": "^21.2.1",
    "@capacitor/android": "^7.6.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^7.6.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "@nx/angular": "22.5.4",
    "@nx/devkit": "22.5.4",
    "@tailwindcss/postcss": "^4.2.1",
    "browserslist": "^4.28.1",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "nx": "22.5.4",
    "peggy": "^5.1.0",
    "rxjs": "~7.8.2",
    "showdown": "^2.1.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@angular/cli": "^21.2.1",
    "@cspell/cspell-types": "^9.7.0",
    "@cspell/dict-de-de": "^4.1.2",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@nx/esbuild": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/plugin": "22.5.4",
    "@nx/storybook": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.58.2",
    "@prettier/plugin-xml": "^3.4.2",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/angular": "^10.2.16",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@tailwindcss/cli": "^4.2.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/utils": "^8.56.1",
    "angular-eslint": "^21.3.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.13.6",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "cspell": "^9.7.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-storybook": "^10.2.16",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.1.1",
    "jest-text-transformer": "^1.0.4",
    "jest-util": "^30.2.0",
    "markdownlint-cli": "^0.48.0",
    "minimatch": "^10.2.4",
    "nx-stylelint": "^18.0.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.16",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "29.4.6",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.56.1"
  }
}
