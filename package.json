{
  "name": "travel-packlist-root",
  "version": "1.5.0",
  "license": "MIT",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "changelog": "conventional-changelog -i CHANGELOG.md -n util/conventionalcommits.mjs",
    "version": "pnpm run changelog -- -s && git add CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "release-notes": "conventional-changelog -r 2 -n util/conventionalcommits.mjs -o",
    "create-prettierignore": "node util/create-prettierignore.mjs",
    "prepare": "husky",
    "dev": "nx serve travel-packlist",
    "start": "nx serve travel-packlist-web"
  },
  "nx": {
    "includedScripts": [
      "dev",
      "start"
    ],
    "implicitDependencies": [
      "check-plugin",
      "libs/*",
      "apps/*"
    ],
    "targets": {
      "design": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx storybook design-system",
            "nx run design-system:compile-styles:watch"
          ],
          "parallel": true
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "lintFilePatterns": [
            "*.*",
            "util/*.*"
          ]
        }
      },
      "markdownlint": {
        "executor": "@travel-packlist/check-plugin:markdown",
        "options": {
          "pattern": "*.md"
        }
      },
      "create-prettierignore": {
        "executor": "nx:run-script",
        "options": {
          "script": "create-prettierignore"
        },
        "inputs": [
          "{workspaceRoot}/util/create-prettierignore.mjs",
          "{workspaceRoot}/**/.gitignore"
        ],
        "outputs": [
          "{workspaceRoot}/.prettierignore"
        ],
        "cache": true
      },
      "format": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "create-prettierignore"
        ],
        "options": {
          "command": "nx format:write --all"
        },
        "configurations": {
          "ci": {
            "command": "nx format:check --all"
          },
          "pre-commit": {
            "command": "nx format:write --uncommitted"
          }
        }
      },
      "dead-code": {
        "executor": "@travel-packlist/check-plugin:dead-code-summary",
        "dependsOn": [
          "^dead-code"
        ],
        "inputs": [
          "{workspaceRoot}/dist/**/dead-code/imports.json",
          "{workspaceRoot}/dist/**/dead-code/exports.json"
        ],
        "cache": false
      }
    }
  },
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "nx",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "lmdb",
      "msgpackr-extract"
    ]
  },
  "dependencies": {
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/animations": "21.1.2",
    "@angular/build": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/localize": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/router": "21.1.2",
    "@angular/service-worker": "21.1.2",
    "@capacitor/android": "^7.4.5",
    "@capacitor/app": "^7.1.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.5",
    "@capacitor/core": "^7.4.5",
    "@capacitor/filesystem": "^7.1.6",
    "@capacitor/share": "^7.0.3",
    "@nx/angular": "22.4.4",
    "@nx/devkit": "22.4.4",
    "@tailwindcss/postcss": "^4.1.18",
    "browserslist": "^4.28.1",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "nx": "22.4.4",
    "peggy": "^5.0.6",
    "rxjs": "~7.8.2",
    "showdown": "^2.1.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@angular/cli": "^21.1.2",
    "@cspell/cspell-types": "^9.6.2",
    "@cspell/dict-de-de": "^4.1.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@nx/esbuild": "22.4.4",
    "@nx/eslint": "22.4.4",
    "@nx/eslint-plugin": "22.4.4",
    "@nx/jest": "22.4.4",
    "@nx/js": "22.4.4",
    "@nx/playwright": "22.4.4",
    "@nx/plugin": "22.4.4",
    "@nx/storybook": "22.4.4",
    "@nx/web": "22.4.4",
    "@nx/workspace": "22.4.4",
    "@playwright/test": "1.58.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@storybook/addon-docs": "10.2.3",
    "@storybook/addon-themes": "10.2.3",
    "@storybook/angular": "10.2.3",
    "@swc-node/register": "^1.11.1",
    "@tailwindcss/cli": "^4.1.18",
    "@types/jest": "30.0.0",
    "@types/node": "25.1.0",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/utils": "^8.54.0",
    "angular-eslint": "21.2.0",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.4",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "cspell": "^9.6.2",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-perfectionist": "^5.4.0",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-storybook": "10.2.3",
    "globals": "^17.2.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-preset-angular": "16.0.0",
    "jest-text-transformer": "^1.0.4",
    "jest-util": "30.2.0",
    "markdownlint-cli": "^0.47.0",
    "minimatch": "^10.1.1",
    "nx-stylelint": "^18.0.2",
    "onchange": "^7.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-sh": "~0.17.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "10.2.3",
    "stylelint": "^17.1.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-jest": "29.4.6",
    "ts-morph": "^27.0.2",
    "ts-node": "10.9.2",
    "typescript-eslint": "^8.54.0"
  }
}
