{
  "overrides": [
    {
      "files": [
        "*.sh",
        ".git*",
        ".*ignore"
      ],
      "options": {
        "indent": 4,
        "parser": "sh"
      }
    },
    {
      "files": [
        "*.js",
        "*.mjs"
      ],
      "options": {
        "trailingComma": "es5"
      }
    },
    {
      "files": [
        "*.svg"
      ],
      "options": {
        "parser": "xml"
      }
    },
    {
      "files": [
        "*.json"
      ],
      "options": {
        "jsonRecursiveSort": true,
        "parser": "json",
        "printWidth": 5
      }
    },
    {
      "files": [
        "*.html"
      ],
      "options": {
        "parser": "angular"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-tailwindcss",
    "prettier-plugin-sh",
    "@prettier/plugin-xml",
    "prettier-plugin-sort-json"
  ],
  "singleQuote": true
}
