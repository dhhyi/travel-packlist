{
  "name": "rules-template",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "{projectRoot}/src",
  "projectType": "library",
  "tags": [
    "scope:generated",
    "localized"
  ],
  "implicitDependencies": [
    "generate-plugin",
    "check-plugin",
    "rules",
    "rules-cmdl"
  ],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^generate"
      ],
      "options": {
        "command": "nx g @travel-packlist/generate-plugin:templates",
        "path": "{projectRoot}/src",
        "pattern": "{projectRoot}/src/txt/*.txt"
      },
      "inputs": [
        "^production",
        "{projectRoot}/src/txt/*.txt"
      ],
      "outputs": [
        "{projectRoot}/src/lib/*.ts",
        "{projectRoot}/src/index.ts"
      ],
      "cache": true
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "{projectRoot}/vite.config.ts"
      }
    },
    "lint": {
      "executor": "@travel-packlist/check-plugin:rules",
      "dependsOn": [
        {
          "projects": [
            "rules-cmdl"
          ],
          "target": "build"
        }
      ],
      "options": {
        "pattern": "{projectRoot}/src/txt/*.txt",
        "errorOnWarnings": true
      },
      "configurations": {
        "ci": {
          "errorOnChange": true
        }
      }
    },
    "dead-code": {
      "executor": "@travel-packlist/check-plugin:dead-code",
      "options": {
        "tsConfig": "{projectRoot}/tsconfig.lib.json"
      }
    }
  }
}
