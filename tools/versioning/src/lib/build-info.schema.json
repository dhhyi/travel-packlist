{
  "$schema": "https://json-schema.org/schema",
  "additionalProperties": false,
  "description": "",
  "properties": {
    "$schema": {
      "description": "The schema version",
      "type": "string"
    },
    "buildTime": {
      "description": "Build time in seconds since epoch",
      "type": "number"
    },
    "commitsSince": {
      "description": "The number of commits since the last tag",
      "type": "number"
    },
    "gitHash": {
      "description": "The git hash of the current commit",
      "type": "string"
    },
    "version": {
      "description": "The version from package.json",
      "type": "string"
    },
    "versionCode": {
      "description": "The version code for the Android application",
      "type": "number"
    }
  },
  "required": [
    "buildTime",
    "version"
  ],
  "title": "Build Info Schema",
  "type": "object",
  "version": 2
}
