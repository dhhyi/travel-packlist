{
  "$schema": "https://json-schema.org/schema",
  "additionalProperties": false,
  "description": "",
  "properties": {
    "exclude": {
      "description": "List of paths glob patterns to exclude from the check",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "noExports": {
      "default": false,
      "description": "Do not try to find exported symbols",
      "type": "boolean"
    },
    "tsConfig": {
      "description": "Path to the tsconfig file",
      "type": "string"
    },
    "verbose": {
      "default": false,
      "description": "Print additional information",
      "type": "boolean"
    }
  },
  "required": [
    "tsConfig"
  ],
  "title": "Executor Schema",
  "type": "object",
  "version": 2
}
