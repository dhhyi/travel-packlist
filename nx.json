{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "playwright",
      "linter": "eslint",
      "style": "none",
      "unitTestRunner": "vitest"
    },
    "@nx/angular:component": {
      "changeDetection": "OnPush",
      "skipTests": true,
      "style": "none",
      "type": "component"
    },
    "@nx/angular:library": {
      "linter": "eslint",
      "setParserOptionsProject": true,
      "unitTestRunner": "vitest"
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "design": [
      "{workspaceRoot}/apps/design-system/src/**/*.css"
    ],
    "production": [
      "default",
      "!{projectRoot}/eslint.config.*",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vite.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s",
      "!{projectRoot}/.stylelintrc.json",
      "!{projectRoot}/**/*.stories.@(js|jsx|ts|tsx|mdx)",
      "!{projectRoot}/storybook/**/*",
      "!{projectRoot}/tsconfig.storybook.json"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/eslint.base.config.mjs"
    ],
    "version": [
      {
        "runtime": "npm pkg get version"
      }
    ]
  },
  "nxCloudId": "676534afe3d486b0dc961fdf",
  "plugins": [
    {
      "options": {
        "exclude": [
          "CHANGELOG.md"
        ]
      },
      "plugin": "@travel-packlist/check-plugin"
    },
    "@travel-packlist/json-schema-to-typescript",
    {
      "options": {
        "testMode": "watch",
        "testTargetName": "test"
      },
      "plugin": "@nx/vitest"
    },
    {
      "options": {
        "targetName": "eslint"
      },
      "plugin": "@nx/eslint/plugin"
    }
  ],
  "targetDefaults": {
    "@nx/angular:application": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": [
        "^build",
        "schema2ts-*"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "options": {
        "assets": [
          "{projectRoot}/*.md",
          {
            "glob": "**/!(*.ts)",
            "input": "./{projectRoot}/src",
            "output": "./src"
          },
          {
            "glob": "**/*.d.ts",
            "input": "./{projectRoot}/src",
            "output": "./src"
          },
          {
            "glob": "generators.json",
            "input": "./{projectRoot}",
            "output": "."
          },
          {
            "glob": "executors.json",
            "input": "./{projectRoot}",
            "output": "."
          }
        ],
        "main": "{projectRoot}/src/index.ts",
        "outputPath": "dist/{projectRoot}",
        "tsConfig": "{projectRoot}/tsconfig.lib.json"
      },
      "outputs": [
        "{options.outputPath}"
      ]
    },
    "@travel-packlist/capacitor-assets:run": {
      "options": {
        "androidProject": "dist/android",
        "assetPath": "apps/travel-packlist/public",
        "darkColor": "#0f172a",
        "lightColor": "#f1f5f9",
        "pwaManifestPath": "apps/travel-packlist/public/manifest.json"
      }
    },
    "@travel-packlist/check-plugin:dead-code": {
      "cache": true,
      "dependsOn": [
        "generate"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}/dead-code/{imports,exports}.json"
      ]
    },
    "@travel-packlist/check-plugin:markdown": {
      "cache": true,
      "configurations": {
        "ci": {
          "fix": false
        },
        "pre-commit": {
          "fix": true
        }
      },
      "defaultConfiguration": "pre-commit",
      "inputs": [
        "{projectRoot}/*.md",
        "!{projectRoot}/CHANGELOG.md",
        "{workspaceRoot}/*.md"
      ]
    },
    "@travel-packlist/check-plugin:tsconfig": {
      "cache": true,
      "configurations": {
        "ci": {
          "fix": false
        },
        "pre-commit": {
          "fix": true
        }
      },
      "defaultConfiguration": "pre-commit"
    },
    "build-storybook": {
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "{projectRoot}/.storybook/**/*",
        "{projectRoot}/tsconfig.storybook.json"
      ]
    },
    "e2e-ci--**/*": {
      "dependsOn": [
        "^build"
      ]
    },
    "eslint": {
      "cache": true,
      "configurations": {
        "ci": {
          "fix": false,
          "max-warnings": 0
        },
        "pre-commit": {
          "fix": true,
          "max-warnings": 0
        }
      },
      "defaultConfiguration": "pre-commit",
      "dependsOn": [
        "generate",
        "schema2ts-*"
      ],
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint*.config.*",
        "{workspaceRoot}/tools/eslint-config/src/**/*.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*"
      ]
    },
    "nx-stylelint:lint": {
      "cache": true,
      "configurations": {
        "ci": {
          "fix": false
        },
        "pre-commit": {
          "fix": true
        }
      },
      "defaultConfiguration": "pre-commit",
      "inputs": [
        "{projectRoot}/**/*.{css,scss}",
        "{projectRoot}/.stylelintrc.json",
        "{workspaceRoot}/util/.stylelintrc.json"
      ],
      "options": {
        "lintFilePatterns": [
          "{projectRoot}/**/*.css"
        ]
      }
    },
    "test": {
      "cache": true,
      "configurations": {
        "pre-commit": {
          "watch": false
        }
      },
      "dependsOn": [
        "^generate",
        "generate"
      ],
      "inputs": [
        "default",
        "^production"
      ]
    }
  }
}
