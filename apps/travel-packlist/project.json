{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "i18n": {
    "locales": {
      "de": "libs/locale/src/messages.de.json"
    },
    "sourceLocale": "en"
  },
  "implicitDependencies": [
    "!design-system",
    "capacitor-assets"
  ],
  "name": "travel-packlist",
  "prefix": "app",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "tags": [
    "scope:main"
  ],
  "targets": {
    "build": {
      "cache": true,
      "configurations": {
        "android": {
          "define": {
            "ANDROID": "true"
          },
          "localize": true,
          "outputHashing": "all",
          "outputPath": "dist/apps/travel-packlist-android"
        },
        "development": {
          "extractLicenses": false,
          "optimization": false,
          "sourceMap": true
        },
        "gh-pages": {
          "baseHref": "/travel-packlist/",
          "localize": true,
          "outputHashing": "all",
          "outputPath": "dist/apps/travel-packlist-gh-pages",
          "serviceWorker": "{projectRoot}/ngsw-config.json"
        },
        "production": {
          "localize": true,
          "outputHashing": "all",
          "outputPath": "dist/apps/travel-packlist-production",
          "serviceWorker": "{projectRoot}/ngsw-config.json"
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": [
        "build-required"
      ],
      "executor": "@nx/angular:application",
      "inputs": [
        "default",
        "^production",
        "design"
      ],
      "options": {
        "assets": [
          {
            "glob": "**/*",
            "input": "{projectRoot}/public"
          }
        ],
        "browser": "{projectRoot}/src/main.ts",
        "budgets": [
          {
            "maximumError": "1mb",
            "maximumWarning": "500kb",
            "type": "initial"
          },
          {
            "maximumError": "8kb",
            "maximumWarning": "4kb",
            "type": "anyComponentStyle"
          }
        ],
        "define": {
          "ANDROID": "false"
        },
        "i18nDuplicateTranslation": "error",
        "i18nMissingTranslation": "error",
        "index": "{projectRoot}/src/index.html",
        "inlineStyleLanguage": "css",
        "outputPath": "dist/apps/travel-packlist",
        "polyfills": [
          "@angular/localize/init"
        ],
        "scripts": [],
        "styles": [
          "apps/design-system/src/styles.css"
        ],
        "tsConfig": "{projectRoot}/tsconfig.app.json"
      },
      "outputs": [
        "{options.outputPath}"
      ]
    },
    "build-required": {
      "dependsOn": [
        "^generate",
        "generate-*"
      ],
      "executor": "nx:noop"
    },
    "dead-code": {
      "executor": "@travel-packlist/check-plugin:dead-code",
      "options": {
        "tsConfig": "{projectRoot}/tsconfig.app.json"
      }
    },
    "extract-i18n": {
      "cache": true,
      "dependsOn": [
        "^generate"
      ],
      "executor": "@nx/angular:extract-i18n",
      "inputs": [
        "production",
        "^production"
      ],
      "options": {
        "buildTarget": "travel-packlist:build:production",
        "format": "json",
        "outputPath": "libs/locale/src"
      },
      "outputs": [
        "{workspaceRoot}/libs/locale/src/messages.json"
      ]
    },
    "generate-assets": {
      "cache": true,
      "executor": "@travel-packlist/capacitor-assets:run",
      "inputs": [
        "{projectRoot}/public/icon.svg",
        "{projectRoot}/public/manifest.json"
      ],
      "options": {
        "type": "pwa"
      },
      "outputs": [
        "{projectRoot}/public/manifest.json",
        "{projectRoot}/public/icon-*.webp"
      ]
    },
    "lint": {
      "dependsOn": [
        "^generate"
      ],
      "executor": "@nx/eslint:lint"
    },
    "serve": {
      "configurations": {
        "android": {
          "buildTarget": "travel-packlist:build:android"
        },
        "development": {
          "buildTarget": "travel-packlist:build:development"
        },
        "production": {
          "buildTarget": "travel-packlist:build:production"
        }
      },
      "continuous": true,
      "defaultConfiguration": "development",
      "dependsOn": [
        "build-required"
      ],
      "executor": "@nx/angular:dev-server",
      "options": {
        "host": "0.0.0.0"
      }
    },
    "test": {
      "options": {
        "config": "../../{projectRoot}/vite.config.ts"
      }
    }
  }
}
