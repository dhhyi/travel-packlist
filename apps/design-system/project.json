{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": [
    "icons"
  ],
  "name": "design-system",
  "projectType": "application",
  "tags": [
    "scope:design"
  ],
  "targets": {
    "build": {
      "cache": true,
      "configurations": {
        "ci": {
          "quiet": true
        }
      },
      "dependsOn": [
        "compile-styles",
        "^generate",
        "^build"
      ],
      "executor": "@storybook/angular:build-storybook",
      "inputs": [
        "default"
      ],
      "options": {
        "browserTarget": "design-system:build",
        "compodoc": false,
        "configDir": "{projectRoot}/storybook",
        "outputDir": "dist/{projectRoot}",
        "styles": [
          "{projectRoot}/storybook/styles.compiled.css"
        ]
      },
      "outputs": [
        "{options.outputDir}"
      ]
    },
    "compile-styles": {
      "cache": true,
      "configurations": {
        "ci": {
          "minify": true
        },
        "watch": {
          "watch": true
        }
      },
      "executor": "nx:run-commands",
      "inputs": [
        "default",
        "{projectRoot}/src/styles.css"
      ],
      "options": {
        "command": "tailwindcss",
        "input": "{projectRoot}/src/styles.css",
        "output": "{projectRoot}/storybook/styles.compiled.css"
      },
      "outputs": [
        "{options.output}"
      ]
    },
    "doc-markdownlint": {
      "executor": "@travel-packlist/check-plugin:markdown",
      "options": {
        "pattern": "{projectRoot}/**/*.mdx"
      }
    },
    "serve": {
      "configurations": {
        "ci": {
          "buildTarget": "design-system:build:ci"
        }
      },
      "dependsOn": [
        "build"
      ],
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "design-system:build",
        "host": "0.0.0.0",
        "port": 4444,
        "spa": true,
        "staticFilePath": "dist/{projectRoot}"
      }
    },
    "storybook": {
      "dependsOn": [
        "compile-styles",
        "^generate",
        "^build"
      ],
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "browserTarget": "design-system:build",
        "compodoc": false,
        "configDir": "{projectRoot}/storybook",
        "host": "0.0.0.0",
        "port": 4444,
        "styles": [
          "{projectRoot}/storybook/styles.compiled.css"
        ]
      }
    },
    "stylelint": {
      "executor": "nx-stylelint:lint",
      "options": {
        "lintFilePatterns": [
          "{projectRoot}/src/**/*.css"
        ]
      }
    }
  }
}
